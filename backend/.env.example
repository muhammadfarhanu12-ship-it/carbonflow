NODE_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173
ADMIN_CLIENT_URLS=http://localhost:3001
MONGO_URI=mongodb://127.0.0.1:27017/carbonflow
MONGO_DB_NAME=carbonflow
MONGO_RETRY_ATTEMPTS=3
MONGO_RETRY_DELAY_MS=2000
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_SECRET=replace-with-a-third-long-random-secret
ADMIN_EMAIL=admin@carbonflow.com
ADMIN_PASSWORD=change-this-admin-password
EMAIL_USER=dev-null@example.com
EMAIL_PASS=replace-with-smtp-password
FROM_EMAIL=CarbonFlow <dev-null@example.com>
CARBON_PRICE_PER_TON=55
SEED_ON_BOOT=false
