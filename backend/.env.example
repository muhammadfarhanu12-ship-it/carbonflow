PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster.mongodb.net/carbon_footprint_app?retryWrites=true&w=majority
MONGO_DB_NAME=carbon_footprint_app
MONGO_RETRY_ATTEMPTS=3
MONGO_RETRY_DELAY_MS=2000
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=12h
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

ADMIN_JWT_SECRET=replace-with-strong-admin-secret
ADMIN_JWT_EXPIRES_IN=12h
ADMIN_EMAIL=admin@carbonflow.com
ADMIN_PASSWORD=replace-with-strong-admin-password

CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:3001
FRONTEND_URL=http://localhost:5173
ADMIN_CLIENT_URL=http://localhost:3001
ADMIN_CLIENT_URLS=http://localhost:3001
BASE_URL=http://localhost:5000

EMAIL_USER=example@gmail.com
EMAIL_PASS=replace-with-gmail-app-password
EMAIL_FROM=no-reply@carbonflow.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=example@gmail.com
SMTP_PASS=replace-with-gmail-app-password
FROM_EMAIL=no-reply@carbonflow.com

CARBON_PRICE_PER_TON=55
SEED_ON_BOOT=false

AI_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_TIMEOUT_MS=12000
AI_TEMPERATURE=0
AI_MAX_OUTPUT_TOKENS=800
AI_SEED=7
