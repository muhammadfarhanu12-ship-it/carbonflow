PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://example
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://carbonflow-nu.vercel.app
ADMIN_URL=https://carbonflow-admin.vercel.app
BACKEND_URL=https://carbonflow-h9cj.onrender.com
CORS_ORIGINS=https://carbonflow-nu.vercel.app,https://carbonflow-admin.vercel.app,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_with_smtp_user
SMTP_PASS=replace_with_smtp_password
EMAIL_FROM="CarbonFlow <no-reply@yourdomain.com>"
STORAGE_PROVIDER=
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=
CRON_SECRET=replace_with_strong_cron_secret
AI_ENABLED=false
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
AI_DATA_RETENTION_MODE=none
AI_REDACT_SENSITIVE_DATA=true
REGISTRY_PROVIDER=disabled
